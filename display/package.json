{
  "name": "save4223-pi-display",
  "version": "1.0.0",
  "description": "Local dashboard display for Smart Cabinet Pi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "test": "jest"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.save4223.pi-display",
    "productName": "Smart Cabinet Display",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css"
    ],
    "linux": {
      "target": "deb",
      "category": "Utility"
    }
  }
}
